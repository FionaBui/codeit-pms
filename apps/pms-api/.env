HOST=localhost
PORT=3000

# CORS: allowed origin for browser requests (default: http://localhost:4200)
# CORS_ORIGIN=http://localhost:4200

# MongoDB
MONGODB_URI=mongodb://localhost:27017/pms

# Azure AD (API authentication, single-tenant)
# - AAD_TENANT_ID: your Azure AD tenant GUID (e.g. from Azure Portal > Azure Active Directory > Overview)
# - AAD_AUDIENCE: must match the "aud" claim in your access token (e.g. api://<api-app-client-id>)
# - AAD_CLIENT_ID: app client id for Graph on-behalf-of (defaults to AAD_AUDIENCE without api:// prefix)
# - AAD_CLIENT_SECRET: client secret for Graph on-behalf-of (required to resolve jobTitle from Graph)
AAD_AUDIENCE=api://a83bdce7-c3d3-4462-a478-720961dc402b
AAD_TENANT_ID=bee816db-e2fb-4f03-9f91-445a05517f0d
AAD_CLIENT_ID=a83bdce7-c3d3-4462-a478-720961dc402b
AAD_CLIENT_SECRET=

# Severa Visma PSA API (OAuth2 client credentials)
SEVERA_CLIENT_ID=
SEVERA_CLIENT_SECRET=

# Workers
# Cron schedule for syncing project actual hours from Severa (default: every hour)
# SYNC_ACTUAL_HOURS_CRON=0 * * * *

