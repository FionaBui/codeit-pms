HOST=localhost
PORT=3000

# CORS: allowed origin for browser requests (default: http://localhost:4200)
# CORS_ORIGIN=http://localhost:4200

# MongoDB
MONGODB_URI=mongodb://localhost:27017/pms

# Azure AD (API authentication, single-tenant)
# - AAD_TENANT_ID: your Azure AD tenant GUID (e.g. from Azure Portal > Azure Active Directory > Overview)
# - AAD_AUDIENCE: must match the "aud" claim in your access token (e.g. api://<api-app-client-id>)
AAD_AUDIENCE=e9511697-6d16-4cab-9b58-0433958fdb71

